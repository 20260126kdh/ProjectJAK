MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1978429808}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 444cc98fce490d541b5383aceb7d30c6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  classDetailPanel: {fileID: 533476692}
  classInfos:
  - playerClass: 1
    className: "\uD53C\uC9C0\uD06C"
    maxHP: 95
    passiveDescription: "\uC804\uD22C \uC885\uB8CC \uC2DC \uCCB4\uB825\uC744 20 \uD68C\uBCF5\uD569\uB2C8\uB2E4."
    description: "\uB2F9\uC2E0\uC740 \uAE34 \uD56D\uD574 \uC138\uC6D4 \uB3D9\uC548
      \uC5BB\uC740 \uBAA8\uB4E0 \uB178\uD558\uC6B0\uC640 \uAE30\uC220\uC744 \uD3EC\uAE30\uD558\uACE0,
      \uC545\uB9C8\uC640 \uACC4\uC57D\uD558\uC5EC \uB2F9\uC2E0\uC758 \uD53C\uB97C
      \uC81C\uBB3C\uB85C \uC0AC\uC6A9\uD574 \uC801\uC744 \uBB34\uCC38\uD788 \uC9D3\uBC1F\uAE30\uB85C
      \uD588\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC758 \uD53C\uAC00 \uB0A8\uC544\uC788\uB294
      \uD55C, \uB04A\uC784\uC5C6\uB294 \uD798\uACFC \uC18D\uC0BC\uC784\uC774 \uD568\uAED8
      \uD560 \uAC83\uC785\uB2C8\uB2E4."
    classImage: {fileID: 0}
  - playerClass: 2
    className: "\uD14C\uD06C\uB2C8\uC158"
    maxHP: 75
    passiveDescription: "\uC801\uC5D0\uAC8C \uC791\uC0B4\uC7A1\uC774 \uC2A4\uD0DD\uC744
      5 \uBD80\uC5EC\uD560 \uB54C \uB9C8\uB2E4 \uCD94\uAC00\uB85C \uC791\uC0B4\uC7A1\uC774
      \uC2A4\uD0DD\uC744 1 \uBD80\uC5EC\uD569\uB2C8\uB2E4."
    description: "\uB2F9\uC2E0\uC740 \uAE34 \uC138\uC6D4\uB3D9\uC548 \uC5BB\uC5B4\uC628
      \uBAA8\uB4E0 \uAE30\uC220\uB4E4\uC744 \uC5F0\uB9C8\uD588\uC2B5\uB2C8\uB2E4.
      \uB2F9\uC2E0\uC758 \uC190 \uB05D\uC5D0\uC11C \uB0A0\uC544\uAC00\uB294 \uC791\uC0B4\uB4E4\uC740
      \uC801\uB4E4\uC758 \uC2EC\uC7A5\uC744 \uAFF0\uB6AB\uACE0 \uC9C0\uB098\uAC08
      \uAC83\uC785\uB2C8\uB2E4."
    classImage: {fileID: 0}
  - playerClass: 3
    className: "\uCEA1\uD2F4"
    maxHP: 75
    passiveDescription: "\uC120\uC6D0\uC744 1\uBA85 \uC18C\uD658\uD569\uB2C8\uB2E4.
      \uC120\uC6D0\uC740 \uACF5\uACA9 \uC2DC\uC5D0 \uC801\uC5D0\uAC8C \uC791\uC0B4\uC7A1\uC774
      \uC2A4\uD0DD\uC744 1 \uBD80\uC5EC\uD569\uB2C8\uB2E4."
    description: "\uB2F9\uC2E0\uC740 \uC545\uB9C8\uC758 \uC720\uBB3C\uC744 \uC190\uC5D0
      \uB123\uC5B4 \uC8FD\uC740 \uC790\uB4E4\uC744 \uBD88\uB7EC\uC62C \uC218 \uC788\uAC8C
      \uB418\uC5C8\uC2B5\uB2C8\uB2E4.  \uC601\uBA74\uC5D0\uC11C \uAE68\uC5B4\uB09C
      \uC601\uD63C\uB4E4\uC740 \uB2F9\uC2E0\uC744 \uC120\uC7A5\uC73C\uB85C \uC778\uC2DD\uD558\uC5EC,
      \uB2F9\uC2E0\uC758 \uBA85\uB839\uC774 \uB05D\uB0A0 \uB54C\uAE4C\uC9C0 \uC55E\uC73C\uB85C
      \uC804\uC9C4\uD558\uACE0, \uCC3D\uC744 \uB358\uC9C8 \uAC83\uC785\uB2C8\uB2E4."
    classImage: {fileID: 0}
  characterImage: {fileID: 1203302800}
